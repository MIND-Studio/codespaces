# mind-codespaces production — example env file.
# Copy to `.env` next to docker-compose.yml and fill in.
# NEVER commit the populated .env (it's already in .gitignore via .env*).
#
# Sections are ordered: required → strongly recommended → optional tuning.

# ====================================================================
# 1. Public-facing hostnames (REQUIRED)
# ====================================================================
# Both subdomains must already point at this VM's IP (A/AAAA records).
# Caddy will issue Let's Encrypt certs automatically on first boot.
MIND_DOMAIN_BRIDGE=codespaces.example.com
MIND_DOMAIN_POD=pod.example.com

# Contact email for Let's Encrypt expiration warnings. Required.
ACME_EMAIL=you@example.com

# ====================================================================
# 2. Required production secrets (REQUIRED)
# ====================================================================
# Generate each with:
#   openssl rand -hex 32   (for the two 32-byte ones)
#   openssl rand -hex 24   (for the hook secret)
# The bridge refuses to start in production with any of these unset.
#
# BRIDGE_SESSION_SECRET  — 32-byte HMAC key for the session cookie. Rotating
#   this invalidates every active session (users must reconnect via /connect).
# BRIDGE_HOOK_SECRET     — Shared secret baked into each repo's post-receive
#   hook script. Rotating this requires `npm run reinstall:hooks` on the VM.
# IDENTITY_ENCRYPTION_KEY — 32-byte AES-256-GCM key for the OIDC refresh
#   tokens / DPoP keys stored in identity_storage. Rotating this orphans
#   existing rows (users must reconnect); back up identity_storage if you
#   care about avoiding the re-auth dance.
BRIDGE_SESSION_SECRET=
BRIDGE_HOOK_SECRET=
IDENTITY_ENCRYPTION_KEY=

# ====================================================================
# 3. Admin / metrics tokens (RECOMMENDED)
# ====================================================================
# BRIDGE_ADMIN_TOKEN  — Bearer token for POST /api/admin/reconcile.
#   Unset = endpoint disabled. Generate with `openssl rand -hex 32`.
# BRIDGE_METRICS_TOKEN — Bearer token for GET /api/metrics (Prometheus).
#   Unset = endpoint refuses all requests. Same length.
BRIDGE_ADMIN_TOKEN=
BRIDGE_METRICS_TOKEN=

# ====================================================================
# 4. Multi-user signup (REQUIRED for managed-multi-user deploys)
# ====================================================================
# BRIDGE_ENABLE_SIGNUP=1 turns on POST /api/signup and the /signup page,
# which provisions a CSS account + pod for each new user. Leave unset
# (or set to anything other than "1") for single-tenant deploys where
# you manage accounts out-of-band.
BRIDGE_ENABLE_SIGNUP=

# Comma-separated list of allowed CORS origins for /api/* routes
# (excluding /api/git/*, which is git Smart-HTTP). The BRIDGE_PUBLIC_URL
# origin is implicitly allowed. Wildcards not supported.
#   e.g. https://app.example.com,https://staging.example.com
BRIDGE_CORS_ALLOWED_ORIGINS=

# Per-user / per-repo quotas. Defaults shown; raise/lower as needed.
# Hitting one returns 429 with code "QUOTA_EXCEEDED".
MAX_REPOS_PER_OWNER=50
MAX_TOKENS_PER_REPO=10
MAX_RUNS_PER_OWNER_PER_DAY=500
MAX_DISK_PER_REPO_BYTES=1073741824

# ====================================================================
# 5. Agents / coder driver (OPTIONAL)
# ====================================================================
# Leave OPENROUTER_API_KEY blank to disable the openrouter + coder
# drivers — the bridge still works, the `echo` stub records dispatches
# as no-ops. Set it to enable real model calls.
OPENROUTER_API_KEY=
MIND_AGENT_MODEL=anthropic/claude-3.5-sonnet

# Coder sandbox image. After you build it (see infra/prod/README.md
# step 5), pin by SHA digest in production:
#   docker inspect --format='{{index .RepoDigests 0}}' mind-codespaces/coder:latest
MIND_CODER_IMAGE=mind-codespaces/coder:latest
MIND_CODER_TIMEOUT=600

# Engineer agent (issue.labeled=ready → opens a PR with proposed edits).
# Off by default — turn on after you've evaluated the coder driver's
# behavior on your hardware.
MIND_ENABLE_ENGINEER_AGENT=

# ====================================================================
# 6. Observability (OPTIONAL — has sane defaults)
# ====================================================================
# Structured log level: trace|debug|info|warn|error. NDJSON by default.
LOG_LEVEL=info
LOG_FORMAT=ndjson

# Workflow run log truncation cap (bytes per run). Default 5 MiB.
MIND_WORKFLOW_LOG_LIMIT=5242880

# Max JSON response body, in bytes. Default 5 MiB. Larger responses
# return 500 RESPONSE_TOO_LARGE — protects against accidental DB dumps.
BRIDGE_MAX_JSON_RESPONSE_BYTES=

# ====================================================================
# 7. Reconciler (OPTIONAL — has sane defaults)
# ====================================================================
# How often the HEAD→last_published_sha reconciler walks every Pages
# repo. Lower = tighter drift window, more CSS load. Default 5min.
MIND_RECONCILE_INTERVAL_MS=300000

# ====================================================================
# 8. Deployment image override (set by CI; manual deploys leave blank)
# ====================================================================
# When set, docker-compose.prod.yml uses this image instead of building
# the bridge on the VM. The deploy workflow writes a digest-pinned ref:
#   ghcr.io/<owner>/<repo>-bridge@sha256:...
# Leave blank for a build-on-VM deploy (the default in docker-compose.yml).
MIND_BRIDGE_IMAGE=

# ====================================================================
# 9. Safety nets — DO NOT enable in production
# ====================================================================
# ALLOW_SEEDED_FALLBACK=1 re-enables the dev-only `alice@…/dev-only-…`
# credential fallback in the publisher. Production deployments MUST
# leave this unset; the bridge refuses to use the seeded creds when
# NODE_ENV=production unless this flag is explicitly set. Setting it
# in prod is a security incident — only present for migration drills.
ALLOW_SEEDED_FALLBACK=
